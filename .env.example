###############################################
# MathPath — environment configuration sample
###############################################
#
# Copy this file to `.env` (in the repo root, next to docker-compose.yml):
#     cp .env.example .env
#
# There are NO hardcoded LLM defaults. You MUST configure either:
#   (A) LLM_ALL_PROVIDER + LLM_ALL_MODEL  →  one model used for everything, OR
#   (B) per-task LLM_<TASK>_PROVIDER + LLM_<TASK>_MODEL  →  configured per stage
#
# Plus the API key for whichever provider(s) you reference.

# ============================================================
# 1. Provider API keys
# ============================================================
# Set the key(s) for the provider(s) you reference below. Unused keys can stay
# blank.

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=


# ============================================================
# 2. ALL — global LLM (highest priority)
# ============================================================
# If BOTH variables below are set, this provider+model pair is used for EVERY
# task. Per-task settings in section 3 are ignored.
#
# Use this when you just want one model to handle everything (simplest setup).

# Example: use OpenAI GPT-4o for everything
# LLM_ALL_PROVIDER=openai
# LLM_ALL_MODEL=gpt-4o

# Example: use Anthropic Claude for everything
# LLM_ALL_PROVIDER=anthropic
# LLM_ALL_MODEL=claude-sonnet-4-20250514

# Example: use Google Gemini for everything (cheapest for vision)
# LLM_ALL_PROVIDER=gemini
# LLM_ALL_MODEL=gemini-2.0-flash

LLM_ALL_PROVIDER=
LLM_ALL_MODEL=


# ============================================================
# 3. Per-task LLM configuration
# ============================================================
# Used ONLY when LLM_ALL_* (section 2) is not configured. Each task you
# actually call must have BOTH its provider and model set, otherwise
# get_llm_client() raises a clear error naming exactly what to fix.
#
# Recommended pattern: route vision-heavy `page_extraction` to a cheap
# multimodal model (Gemini Flash), and use a stronger reasoning model
# (GPT-4o / Claude Sonnet) for the rest.
#
# Provider must be one of: openai | anthropic | gemini

# ---- Vision PDF ingestion (multimodal — gets PDF page images)
# Cheap & fast multimodal preferred here.
LLM_PAGE_EXTRACTION_PROVIDER=
LLM_PAGE_EXTRACTION_MODEL=

# ---- Book profiling (subject/level/style detection from chunk samples)
LLM_BOOK_PROFILING_PROVIDER=
LLM_BOOK_PROFILING_MODEL=

# ---- Concept extraction (per-chunk concept mining)
LLM_CONCEPT_EXTRACTION_PROVIDER=
LLM_CONCEPT_EXTRACTION_MODEL=

# ---- Concept de-duplication (LLM tie-breaker for near-duplicate concepts)
LLM_CONCEPT_DEDUP_PROVIDER=
LLM_CONCEPT_DEDUP_MODEL=

# ---- Concept graph building (prerequisite/related edges)
LLM_CONCEPT_GRAPH_PROVIDER=
LLM_CONCEPT_GRAPH_MODEL=

# ---- Tidbit (study plan) generation
LLM_TIDBIT_PLANNING_PROVIDER=
LLM_TIDBIT_PLANNING_MODEL=

# ---- Lesson body generation
LLM_LESSON_GENERATION_PROVIDER=
LLM_LESSON_GENERATION_MODEL=

# ---- Proof ladder (step-by-step proof) generation
LLM_PROOF_LADDER_PROVIDER=
LLM_PROOF_LADDER_MODEL=

# ---- Quiz generation
LLM_QUIZ_GENERATION_PROVIDER=
LLM_QUIZ_GENERATION_MODEL=

# ---- Free-text answer grading
LLM_ANSWER_GRADING_PROVIDER=
LLM_ANSWER_GRADING_MODEL=


# ============================================================
# 4. Vision PDF ingestion (B14v2)
# ============================================================
# When VISION_INGESTION_ENABLED=false (default) the legacy text-extraction PDF
# path is used. When true, PDF uploads run the multimodal page extractor that
# captures chapter/section structure, typed content blocks, and figures in one
# pass. See docs/implementation/B14v2_vision_ingestion.md.
#
# Per-upload override: pass ?use_vision=true on POST /api/books/upload.

VISION_INGESTION_ENABLED=false

# Render DPI for the page images sent to the LLM during the structure pass.
# 150 is plenty for layout + math reading. Lower = cheaper, higher = more
# accurate on small/dense pages.
VISION_RENDER_DPI=150

# DPI used when re-rendering figure crops. Higher than VISION_RENDER_DPI so
# extracted figures are crisp when displayed in the app.
VISION_FIGURE_DPI=200

# How many pages are bundled into a single LLM call. 5 balances cross-page
# context (chapter starts that span pages, multi-page proofs) vs call size.
VISION_BATCH_SIZE=5


# ============================================================
# 5. Mastery tuning
# ============================================================
# Score thresholds that drive the next-item selector after a quiz attempt.
# >= CONTINUE  -> advance to the next tidbit
# >= REVIEW    -> review variant of the same tidbit
# <  REVIEW    -> remedial path (drop a level, more scaffolding)
# Defaults match what the docs describe; rarely worth changing.
# MASTERY_CONTINUE_THRESHOLD=0.7
# MASTERY_REVIEW_THRESHOLD=0.4


# ============================================================
# 6. Advanced
# ============================================================
# Database connection. Override only if you're not using docker-compose.
DATABASE_URL=postgresql://mathpath:mathpath@db:5432/mathpath

# Logging. INFO for normal use, DEBUG for verbose LLM call traces.
LOG_LEVEL=INFO
DEBUG=true
